# cookafeast — cấu hình tuỳ chọn (sao chép thành .env nếu cần)

# Cổng server (mặc định 8088)
# PORT=8088

# Lớp gợi ý thực đơn: "rule" (mặc định, chạy offline) hoặc "claude" (AI)
# SUGGESTION_PROVIDER=rule

# Chỉ cần khi SUGGESTION_PROVIDER=claude — khoá API Anthropic
# Lấy tại https://console.anthropic.com/ . KHÔNG commit khoá thật.
# ANTHROPIC_API_KEY=sk-ant-...
